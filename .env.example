APP_NAME=CodeSentinel API
APP_ENV=local
APP_DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

LOG_LEVEL=INFO

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=codesentinel
POSTGRES_USER=codesentinel
POSTGRES_PASSWORD=codesentinel

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=codesentinel
RABBITMQ_PASSWORD=codesentinel
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=codesentinel.events
RABBITMQ_GITHUB_WEBHOOK_QUEUE=codesentinel.github.webhooks
RABBITMQ_GITHUB_WEBHOOK_ROUTING_KEY=github.webhook.received
RABBITMQ_CONNECT_RETRIES=10
RABBITMQ_CONNECT_RETRY_DELAY_SECONDS=2.0
PLANNER_WORKER_PREFETCH_COUNT=5

GITHUB_WEBHOOK_SECRET=change-me
GITHUB_TOKEN=mock-token

OPENAI_API_KEY=mock-key
# OPENAI_API_BASE=https://api.groq.com/openai/v1
OPENAI_MODEL=gpt-4o-mini
